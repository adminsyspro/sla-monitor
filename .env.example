# Generate with: openssl rand -hex 32
PROBER_TOKEN=replace-me-with-32-byte-hex
AUTH_SECRET=replace-me-with-32-byte-hex

# Set to true only when the app is served over HTTPS.
FORCE_HTTPS=false

# SQLite database location inside the web container.
DATABASE_URL=file:/app/data/sla-monitor.db

# Prober tuning
POLL_INTERVAL_SECONDS=5
MAX_CONCURRENT_CHECKS=50
CLEANUP_INTERVAL_SECONDS=3600
LOG_LEVEL=INFO
